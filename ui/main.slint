import { Button, CheckBox, SpinBox, Slider, GroupBox, LineEdit, ComboBox, TextEdit } from "std-widgets.slint";

export component MainWindow inherits Window {
    title: "OCR Translator";
    icon: @image-url("../app.ico");
    width: 400px;
    height: 780px;
    background: @linear-gradient(180deg, #f8fafc 0%, #f1f5f9 100%);
    default-font-family: "Yu Gothic UI";

    in-out property <bool> is_running: false;
    in-out property <string> api_endpoint: "http://localhost:1234/v1";
    in-out property <string> api_key: "";
    in-out property <string> model_name: "qwen3.5-4b";
    in property <[string]> model_options: ["qwen3.5-4b", "qwen/qwen3.5-9b"];
    in-out property <float> interval: 0;
    in-out property <bool> overlay_visible: true;
    in-out property <string> system_prompt: "naturally translate into korean. only show translated texts.";
    in-out property <float> base_font_size: 18;

    
    
    callback start_stop_clicked();
    callback select_area_clicked();
    callback api_type_changed(string);
    callback overlay_toggle_clicked(bool);
    callback refresh_models_clicked();

    VerticalLayout {
        padding: 14px;
        padding-bottom: 30px; // Increased bottom padding to lift content
        spacing: 10px;

        Text {
            text: "OCR Translator";
            font-size: 18px;
            color: #2563eb;
            horizontal-alignment: center;
            font-weight: 800;
        }

        Rectangle {
            background: #ffffff;
            border-radius: 12px;
            border-width: 1px;
            border-color: #e2e8f0;
            
            VerticalLayout {
                spacing: 8px;
                padding: 10px;
                Text { text: "API SETTINGS"; font-weight: 700; color: #2563eb; font-size: 14px; }
                
                VerticalLayout {
                    spacing: 4px;
                    Text { text: "Provider:"; color: #64748b; font-size: 12px; }
                    ComboBox {
                        model: ["LMStudio", "Google Gemini"];
                        current-value: "LMStudio";
                        selected(value) => {
                            api_type_changed(value);
                        }
                    }
                }

                VerticalLayout {
                    spacing: 4px;
                    Text { text: "Endpoint:"; color: #64748b; font-size: 12px; }
                    LineEdit {
                        text <=> api_endpoint;
                        placeholder-text: "http://localhost:1234/v1";
                    }
                }
                
                VerticalLayout {
                    spacing: 4px;
                    Text { text: "API Key:"; color: #64748b; font-size: 12px; }
                    LineEdit {
                        text <=> api_key;
                        input-type: password;
                        placeholder-text: "Leave empty for LMStudio";
                    }
                }
                
                VerticalLayout {
                    spacing: 4px;
                    Text { text: "Model Name (Edit / Preset):"; color: #64748b; font-size: 12px; }
                    LineEdit {
                        text <=> model_name;
                    }
                    HorizontalLayout {
                        spacing: 6px;
                        ComboBox {
                            model: model_options;
                            current-value: model_name;
                            selected(val) => {
                                model_name = val;
                            }
                        }
                        Button {
                            text: "Sync";
                            primary: false;
                            clicked => { refresh_models_clicked(); }
                        }
                    }
                }

                VerticalLayout {
                    spacing: 4px;
                    Text { text: "System Prompt:"; color: #64748b; font-size: 12px; }
                    Rectangle {
                        background: #f8fafc;
                        border-radius: 4px;
                        border-width: 1px;
                        border-color: #e2e8f0;
                        height: 90px;
                        TextEdit {
                            text <=> system_prompt;
                            width: 100%;
                            height: 100%;
                            font-size: 13px;
                        }
                    }
                }
            }
        }

        Rectangle {
            background: #ffffff;
            border-radius: 12px;
            border-width: 1px;
            border-color: #e2e8f0;
            
            VerticalLayout {
                spacing: 8px;
                padding: 10px;
                Text { text: "CAPTURE SETTINGS"; font-weight: 700; color: #2563eb; font-size: 14px; }
                
                HorizontalLayout {
                    Text { text: "Interval (s): "; vertical-alignment: center; color: #64748b; }
                    Text { text: interval == 0 ? "Once" : round(interval); vertical-alignment: center; font-weight: 700; color: #1e293b; }
                }
                Slider {
                    minimum: 0;
                    maximum: 10;
                    value <=> interval;
                }
                HorizontalLayout {
                    Text { text: "Font Size: "; vertical-alignment: center; color: #64748b; }
                    Text { text: round(base_font_size); vertical-alignment: center; font-weight: 700; color: #1e293b; }
                }
                Slider {
                    minimum: 12;
                    maximum: 40;
                    value <=> base_font_size;
                }

                HorizontalLayout {
                    spacing: 8px;
                    Button {
                        text: "SELECT AREA (Win + `)";
                        clicked => { select_area_clicked(); }
                    }
                    Rectangle {
                        background: #f8fafc;
                        border-radius: 8px;
                        border-width: 1px;
                        border-color: #e2e8f0;
                        height: 32px;
                        HorizontalLayout {
                            padding-left: 8px;
                            padding-right: 8px;
                            spacing: 4px;
                            Text { text: "Overlay"; vertical-alignment: center; font-size: 12px; color: #64748b; }
                            CheckBox {
                                checked <=> overlay_visible;
                                toggled => { overlay_toggle_clicked(self.checked); }
                            }
                        }
                    }
                }
            }
        }

        Rectangle { /* Spacer to push button group down */ }

        VerticalLayout {
            spacing: 12px; // Space between Button and Idle text
            
            Button {
                text: is_running ? "STOP" : "START";
                height: 50px;
                primary: true;
                clicked => { start_stop_clicked(); }
            }

            Text {
                text: is_running ? "● Active" : "○ Idle";
                color: is_running ? #4caf50 : #94a3b8;
                horizontal-alignment: center;
                font-size: 12px;
            }
        }

        Rectangle { height: 10px; } // Extra spacer at the very bottom to lift it slightly more
    }
}

export component OverlayWindow inherits Window {
    always-on-top: true;
    background: transparent;
    no-frame: true;
    icon: @image-url("../app.ico");
    default-font-family: "Yu Gothic UI";
    
    in-out property <length> window_x;
    in-out property <length> window_y;
    in-out property <length> window_w;
    in-out property <length> window_h;

    x: window_x;
    y: window_y;
    width: window_w;
    height: window_h;

    in-out property <string> translated_text: "";
    in-out property <bool> is_searching: false;
    in-out property <bool> show_text: false;
    in-out property <length> font_size: 16px;
    callback close_clicked();

    Rectangle {
        visible: show_text && translated_text != "";
        background: #ffffffe6;
        border-radius: 12px;
        border-width: 1px;
        border-color: #e2e8f0;
        
        // Close Button (X)
        Rectangle {
            x: parent.width - 28px;
            y: 4px;
            width: 24px;
            height: 24px;
            border-radius: 12px;
            background: close_touch.has-hover ? #0000001a : #00000000;
            
            Text {
                text: "×";
                font-size: 20px;
                color: close_touch.has-hover ? #ef4444 : #64748b;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
            
            close_touch := TouchArea {
                clicked => { close_clicked(); }
            }
        }
        
        VerticalLayout {
            padding: 16px;
            padding-top: 24px; // Spacing for the close button
            Text {
                text: translated_text;
                color: #1e293b;
                font-size: font_size;
                wrap: word-wrap;
                horizontal-alignment: left;
                vertical-alignment: center; // Auto font-size handles fitting, center looks better
                font-weight: 500;
            }
        }
    }
}

export component SelectionWindow inherits Window {
    always-on-top: true;
    background: black;
    no-frame: true;
    icon: @image-url("../app.ico");
    default-font-family: "Yu Gothic UI";
    
    in-out property <image> screenshot;
    property <bool> selecting: false;
    property <length> start_x;
    property <length> start_y;
    property <length> current_x;
    property <length> current_y;
    
    // Optimized selection properties for stable calculation
    property <length> sel_x: start_x < current_x ? start_x : current_x;
    property <length> sel_y: start_y < current_y ? start_y : current_y;
    property <length> sel_w: abs_len(current_x - start_x);
    property <length> sel_h: abs_len(current_y - start_y);

    function abs_len(v: length) -> length {
        return v < 0px ? -v : v;
    }

    callback area_selected(length, length, length, length);
    callback closed();

    public function reset() {
        start_x = 0px;
        start_y = 0px;
        current_x = 0px;
        current_y = 0px;
        selecting = false;
    }

    // The base screenshot
    Image {
        source: screenshot;
        width: 100%;
        height: 100%;
    }

    // Dimmed background parts
    // Top
    Rectangle {
        x: 0; y: 0; width: parent.width;
        height: sel_y;
        background: #00000080;
    }
    // Bottom
    Rectangle {
        x: 0; 
        y: sel_y + sel_h;
        width: parent.width;
        height: parent.height - self.y;
        background: #00000080;
    }
    // Left
    Rectangle {
        x: 0;
        y: sel_y;
        width: sel_x;
        height: sel_h;
        background: #00000080;
    }
    // Right
    Rectangle {
        x: sel_x + sel_w;
        y: sel_y;
        width: parent.width - self.x;
        height: sel_h;
        background: #00000080;
    }
    
    // Always show a base dim when NOT selecting to avoid jump
    // Removed redundant Rectangle that caused flicker during transition

    i_touch := TouchArea {
        pointer-event(event) => {
            if (event.button == PointerEventButton.left) {
                if (event.kind == PointerEventKind.down) {
                    selecting = true;
                    start_x = i_touch.mouse-x;
                    start_y = i_touch.mouse-y;
                    current_x = start_x;
                    current_y = start_y;
                } else if (event.kind == PointerEventKind.up) {
                    selecting = false;
                    // Provide the calculated rect
                    area_selected(
                        start_x < current_x ? start_x : current_x,
                        start_y < current_y ? start_y : current_y,
                        abs_len(current_x - start_x),
                        abs_len(current_y - start_y)
                    );
                }
            }
        }
        moved => {
            if (selecting) {
                current_x = i_touch.mouse-x;
                current_y = i_touch.mouse-y;
            }
        }
    }

    forward-focus: key-handler;
    key-handler := FocusScope {
        key-pressed(event) => {
            if (event.text == Key.Escape) {
                selecting = false;
                closed();
                return accept;
            }
            return reject;
        }
    }

    // Selection border
    Rectangle {
        x: sel_x;
        y: sel_y;
        width: sel_w;
        height: sel_h;
        border-color: #2563eb;
        border-width: selecting ? 2px : 0px; // Use border-width for smoother appearance
        background: transparent;
    }
    
    VerticalLayout {
        alignment: start;
        padding: 40px;
        Text {
            text: "Drag your mouse to select capture area";
            color: white;
            font-size: 24px;
            font-weight: 700;
            horizontal-alignment: center;
            opacity: selecting ? 0 : 1; // Use opacity for smoother transition
        }
    }
}
